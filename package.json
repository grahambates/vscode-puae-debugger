{
  "name": "vscode-vamiga-debugger",
  "displayName": "VAmiga Debugger",
  "description": "Debug Amiga programs with an integrated VAmiga emulator in vscode",
  "version": "1.3.0",
  "author": "Graham Bates",
  "publisher": "gigabates",
  "license": "SEE LICENSE IN LICENSE.txt",
  "preview": false,
  "repository": "https://github.com/grahambates/vscode-vamiga-debugger.git",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "amiga",
    "debugger",
    "m68k",
    "vamiga",
    "assembly"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onDebugResolve:vamiga"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vamiga-debugger.eof",
        "title": "End of Frame",
        "icon": "$(run-below)",
        "enablement": "debugType == 'vamiga' && debugState == 'stopped'"
      },
      {
        "command": "vamiga-debugger.eol",
        "title": "End of Line",
        "icon": "$(debug-line-by-line)",
        "enablement": "debugType == 'vamiga' && debugState == 'stopped'"
      },
      {
        "command": "vamiga-debugger.openMemoryViewer",
        "title": "VAmiga: Open Memory Viewer",
        "icon": "$(symbol-array)"
      },
      {
        "command": "vamiga-debugger.viewVariableInMemory",
        "title": "View in Memory Viewer"
      },
      {
        "command": "vamiga-debugger.openStateViewer",
        "title": "VAmiga: Open State Viewer",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "vamiga-debugger.openPuae",
        "title": "vAmiga (PUAE): Open Webview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "debugType == 'vamiga'"
        },
        {
          "command": "vamiga-debugger.viewVariableInMemory",
          "when": "false"
        },
        {
          "command": "vamiga-debugger.openStateViewer",
          "when": "debugType == 'vamiga'"
        }
      ],
      "debug/toolBar": [
        {
          "command": "vamiga-debugger.eof",
          "when": "debugType == 'vamiga'",
          "group": "navigation@51"
        },
        {
          "command": "vamiga-debugger.eol",
          "when": "debugType == 'vamiga'",
          "group": "navigation@52"
        },
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "debugType == 'vamiga'",
          "group": "navigation@53"
        },
        {
          "command": "vamiga-debugger.openStateViewer",
          "when": "debugType == 'vamiga'",
          "group": "navigation@54"
        }
      ],
      "debug/variables/context": [
        {
          "command": "vamiga-debugger.viewVariableInMemory",
          "when": "debugType == 'vamiga'"
        }
      ],
      "editor/context": [
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "debugType == 'vamiga' && editorLangId == m68k",
          "group": "debug@1"
        }
      ]
    },
    "configuration": {
      "title": "Vamiga Debugger",
      "properties": {
        "vamiga-debugger.defaultViewColumn": {
          "type": "string",
          "enum": [
            "one",
            "two",
            "three",
            "beside",
            "active"
          ],
          "enumDescriptions": [
            "First editor column",
            "Second editor column",
            "Third editor column",
            "Next to the active editor",
            "Same column as active editor"
          ],
          "default": "beside",
          "description": "Default position for the Vamiga emulator window"
        },
        "vamiga-debugger.memoryViewer.colorCodeHexBytes": {
          "type": "boolean",
          "default": true,
          "description": "Color-code byte/word/longword values in the memory viewer's Hex view by their leading hex digit, making patterns in the data easier to spot at a glance"
        }
      }
    },
    "breakpoints": [
      {
        "language": "m68k"
      }
    ],
    "debuggers": [
      {
        "type": "vamiga",
        "languages": [
          "m68k"
        ],
        "label": "vAmiga Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Amiga program to run",
                "default": "${workspaceFolder}/out/a.exe"
              },
              "debugProgram": {
                "type": "string",
                "description": "Optional alternate path to program file containing debug symbols. Defaults to same as 'program'. Making a separate build allows for a smaller exe loaded by the Amiga, which uses less RAM and loads faster.",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "Enable logging of the Debug Adapter Protocol",
                "default": false
              },
              "fastLoad": {
                "type": "boolean",
                "description": "Inject program directly into memory",
                "default": false
              },
              "emulatorBackend": {
                "type": "string",
                "enum": [
                  "vamiga",
                  "puae"
                ],
                "enumDescriptions": [
                  "WinUAE-based vAmiga emulator (default)",
                  "PUAE/ami9000 wasm emulator"
                ],
                "default": "vamiga",
                "description": "Emulator backend to debug against"
              },
              "emulatorOptions": {
                "type": "object",
                "properties": {
                  "kickstartRomPath": {
                    "type": "string",
                    "description": "Path to kickstart ROM file"
                  },
                  "kickstartExtPath": {
                    "type": "string",
                    "description": "Path to extended kickstart ROM file"
                  },
                  "cpuRevision": {
                    "type": "string",
                    "enum": [
                      "68000",
                      "68010",
                      "68020",
                      "68030",
                      "68040",
                      "68060",
                      "fake_68030"
                    ],
                    "description": "CPU model. \"fake_68030\" is a vAmiga-only approximate 68030 (no MMU); \"68030\"/\"68040\"/\"68060\" are real CPUs supported by PUAE only. Unsupported combinations throw a validation error at launch."
                  },
                  "chipRam": {
                    "type": "string",
                    "enum": [
                      "256k",
                      "512k",
                      "1M",
                      "2M"
                    ],
                    "description": "Chip RAM size"
                  },
                  "slowRam": {
                    "type": "string",
                    "enum": [
                      "0",
                      "256k",
                      "512k"
                    ],
                    "description": "Slow RAM size"
                  },
                  "fastRam": {
                    "type": "string",
                    "enum": [
                      "0",
                      "256k",
                      "512k",
                      "1M",
                      "2M",
                      "8M"
                    ],
                    "description": "Fast RAM size"
                  },
                  "configFilePath": {
                    "type": "string",
                    "description": "PUAE only: path to a WinUAE-format .uae config file, loaded as the base configuration (e.g. a quickstart=A1200,1 preset). Overridden by emulatorOptions.puae, which is itself overridden by chipRam/slowRam/fastRam/cpuRevision"
                  },
                  "vamiga": {
                    "type": "object",
                    "description": "vAmiga-only options, ignored by other backends",
                    "properties": {
                      "useArosRom": {
                        "type": "boolean",
                        "description": "Use free AROS ROMs"
                      },
                      "showNavBar": {
                        "type": "boolean",
                        "description": "Show navigation bar"
                      },
                      "wideScreen": {
                        "type": "boolean",
                        "description": "Stretch to full width, regardless of aspect ratio"
                      },
                      "darkMode": {
                        "type": "boolean",
                        "description": "Dark mode"
                      },
                      "enableMouse": {
                        "type": "boolean",
                        "description": "Enable mouse"
                      },
                      "displayZoom": {
                        "type": "string",
                        "enum": [
                          "viewport tracking",
                          "borderless",
                          "narrow",
                          "standard",
                          "wider",
                          "overscan",
                          "extreme"
                        ],
                        "description": "Display zoom mode"
                      },
                      "useGpu": {
                        "type": "boolean",
                        "description": "Render with GPU, rather than software"
                      },
                      "agnusRevision": {
                        "type": "string",
                        "enum": [
                          "OCS_OLD",
                          "OCS",
                          "ECS_1MB",
                          "ECS_2MB"
                        ],
                        "description": "Agnus chip revision"
                      },
                      "deniseRevision": {
                        "type": "string",
                        "enum": [
                          "OCS",
                          "ECS"
                        ],
                        "description": "Denise chip revision"
                      },
                      "cpuSpeed": {
                        "type": "string",
                        "enum": [
                          "7MHz",
                          "14Hz",
                          "21Hz",
                          "28Hz",
                          "35Hz",
                          "43Hz",
                          "57Hz",
                          "85Hz",
                          "99Hz"
                        ],
                        "description": "CPU speed"
                      },
                      "blitterAccuracy": {
                        "type": "number",
                        "enum": [
                          0,
                          1,
                          2
                        ],
                        "description": "Blitter accuracy level"
                      },
                      "floppyDriveCount": {
                        "type": "number",
                        "enum": [
                          1,
                          2,
                          3,
                          4
                        ],
                        "description": "Number of floppy drives"
                      },
                      "driveSpeed": {
                        "type": "number",
                        "enum": [
                          -1,
                          1,
                          2,
                          4,
                          8
                        ],
                        "description": "Floppy drive speed multiplier (-1: auto)"
                      }
                    }
                  },
                  "puae": {
                    "type": "object",
                    "description": "PUAE only: raw .uae key=value overrides. Overrides configFilePath, but is itself overridden by chipRam/slowRam/fastRam/cpuRevision. A curated set of commonly-used keys is listed below, but any WinUAE-format .uae key is accepted",
                    "properties": {
                      "quickstart": {
                        "type": "string",
                        "pattern": "^(A500\\+?|A600|A1000|A1200|A3000|A4000T?|CD32|CDTV-CR|CDTV|ARCADIA),\\d+$",
                        "description": "WinUAE-style machine preset: \"<Model>,<ConfigIndex>\", e.g. \"A1200,1\". Model is one of A500/A500+/A600/A1000/A1200/A3000/A4000/A4000T/CD32/CDTV/CDTV-CR/ARCADIA. ConfigIndex selects a model-specific memory/expansion preset (e.g. for A500: 0=KS1.3 OCS Agnus 512k+512k, 1=KS1.3 ECS Agnus 512k+512k, 2=1MB chip). Resets chipset/CPU/RAM, so put it in configFilePath (lowest precedence) rather than here if also using chipRam/slowRam/fastRam/cpuRevision"
                      },
                      "chipset": {
                        "type": "string",
                        "enum": [
                          "ocs",
                          "ecs_agnus",
                          "ecs_denise",
                          "ecs",
                          "aga"
                        ],
                        "description": "Chipset revision"
                      },
                      "chipset_compatible": {
                        "type": "string",
                        "enum": [
                          "-",
                          "Generic",
                          "CDTV",
                          "CDTV-CR",
                          "CD32",
                          "A500",
                          "A500+",
                          "A600",
                          "A1000",
                          "A1200",
                          "A2000",
                          "A3000",
                          "A3000T",
                          "A4000",
                          "A4000T",
                          "Velvet",
                          "Casablanca",
                          "DraCo"
                        ],
                        "description": "Machine compatibility preset (chipset timing/quirks)"
                      },
                      "cpu_compatible": {
                        "type": "boolean",
                        "description": "Enable CPU compatibility mode (more accurate but slower)"
                      },
                      "cpu_24bit_addressing": {
                        "type": "boolean",
                        "description": "Restrict CPU to 24-bit addressing (must be false for Z3/P96 fast RAM to work)"
                      },
                      "cpu_cycle_exact": {
                        "type": "boolean",
                        "description": "Cycle-exact CPU emulation"
                      },
                      "blitter_cycle_exact": {
                        "type": "boolean",
                        "description": "Cycle-exact blitter emulation"
                      },
                      "immediate_blits": {
                        "type": "boolean",
                        "description": "Perform blits immediately, ignoring blitter timing"
                      },
                      "cpu_speed": {
                        "description": "CPU speed: \"max\" (unlimited), \"real\" (real Amiga speed), or an integer multiplier from 1 to 20",
                        "oneOf": [
                          {
                            "type": "string",
                            "enum": [
                              "max",
                              "real"
                            ]
                          },
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 20
                          }
                        ]
                      },
                      "finegrain_cpu_speed": {
                        "type": "integer",
                        "description": "Fine-grained CPU speed setting (alternative to cpu_speed)"
                      },
                      "collision_level": {
                        "type": "string",
                        "enum": [
                          "none",
                          "sprites",
                          "playfields",
                          "full"
                        ],
                        "description": "Sprite/playfield collision detection level"
                      },
                      "floppy_speed": {
                        "type": "integer",
                        "description": "Floppy drive speed as a percentage of real speed (0 = turbo/instant)"
                      },
                      "nr_floppies": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 4,
                        "description": "Number of floppy drives"
                      },
                      "floppy0type": {
                        "type": "integer",
                        "enum": [
                          -1,
                          0,
                          1,
                          2
                        ],
                        "description": "DF0: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                      },
                      "floppy1type": {
                        "type": "integer",
                        "enum": [
                          -1,
                          0,
                          1,
                          2
                        ],
                        "description": "DF1: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                      },
                      "floppy2type": {
                        "type": "integer",
                        "enum": [
                          -1,
                          0,
                          1,
                          2
                        ],
                        "description": "DF2: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                      },
                      "floppy3type": {
                        "type": "integer",
                        "enum": [
                          -1,
                          0,
                          1,
                          2
                        ],
                        "description": "DF3: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                      },
                      "sound_output": {
                        "type": "string",
                        "enum": [
                          "none",
                          "interrupts",
                          "good",
                          "best"
                        ],
                        "description": "Sound emulation quality/method"
                      },
                      "sound_stereo_separation": {
                        "type": "integer",
                        "description": "Stereo separation level"
                      },
                      "sound_frequency": {
                        "type": "integer",
                        "description": "Audio sample rate in Hz"
                      },
                      "gfx_center_horizontal": {
                        "type": "string",
                        "enum": [
                          "none",
                          "simple",
                          "smart"
                        ],
                        "description": "Horizontal display centering"
                      },
                      "gfx_center_vertical": {
                        "type": "string",
                        "enum": [
                          "none",
                          "simple",
                          "smart"
                        ],
                        "description": "Vertical display centering"
                      }
                    },
                    "additionalProperties": {
                      "type": [
                        "string",
                        "number",
                        "boolean"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "vamiga",
            "request": "launch",
            "name": "Launch vAmiga",
            "program": "${workspaceFolder}/out/a.exe",
            "fastLoad": true,
            "stopOnEntry": true,
            "emulatorOptions": {
              "kickstartRomPath": "${workspaceFolder}/roms/kick13.rom",
              "chipRam": "512k",
              "slowRam": "512k",
              "fastRam": "0",
              "cpuRevision": "68000",
              "vamiga": {
                "agnusRevision": "OCS",
                "deniseRevision": "OCS",
                "blitterAccuracy": 2,
                "cpuSpeed": "7MHz"
              }
            }
          }
        ],
        "configurationSnippets": [
          {
            "label": "vAmiga: OCS 512k + 512k Slow",
            "description": "A500 OCS with 512k chip and slow RAM",
            "body": {
              "type": "vamiga",
              "request": "launch",
              "name": "vAmiga: OCS 512k + 512k Slow",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "emulatorOptions": {
                "kickstartRomPath": "^\"\\${workspaceFolder\\}/${2:roms/kick13.rom}\"",
                "chipRam": "512k",
                "slowRam": "512k",
                "fastRam": "0",
                "cpuRevision": "68000",
                "vamiga": {
                  "agnusRevision": "OCS",
                  "deniseRevision": "OCS",
                  "blitterAccuracy": 2,
                  "cpuSpeed": "7MHz"
                }
              }
            }
          },
          {
            "label": "vAmiga: ECS 1M + 1M Fast",
            "description": "A500 ECS with 1M chip and 1M fast RAM",
            "body": {
              "type": "vamiga",
              "request": "launch",
              "name": "vAmiga: ECS 1M + 1M Fast",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "emulatorOptions": {
                "kickstartRomPath": "^\"\\${workspaceFolder\\}/${2:roms/kick310.rom}\"",
                "chipRam": "1M",
                "slowRam": "0",
                "fastRam": "1M",
                "cpuRevision": "68000",
                "vamiga": {
                  "agnusRevision": "ECS_2MB",
                  "deniseRevision": "ECS",
                  "blitterAccuracy": 2,
                  "cpuSpeed": "7MHz"
                }
              }
            }
          },
          {
            "label": "vAmiga (PUAE)",
            "description": "PUAE/ami9000 wasm backend (chipRam/slowRam/fastRam/cpuRevision, configFilePath and emulatorOptions.puae are supported; emulatorOptions.vamiga is ignored)",
            "body": {
              "type": "vamiga",
              "request": "launch",
              "name": "vAmiga (PUAE)",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "emulatorBackend": "puae",
              "emulatorOptions": {
                "kickstartRomPath": "^\"\\${workspaceFolder\\}/${2:roms/kick13.rom}\"",
                "chipRam": "1M",
                "fastRam": "2M",
                "puae": {
                  "gfx_correct_aspect": "true"
                }
              }
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm run check-types && node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit && tsc --noEmit -p src/webview/tsconfig.json",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts,tsx",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.41",
    "@vscode/debugadapter": "^1.68.0",
    "downshift": "^9.0.10",
    "expr-eval": "^2.0.2",
    "m68kdecode": "^1.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.104.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vscode-elements/elements": "^2.3.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "sinon": "^21.0.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "extension.test.ts",
      "integration.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/test/**/*"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/jestSetup.ts"
    ]
  }
}
