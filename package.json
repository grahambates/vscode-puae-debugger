{
  "name": "vscode-vamiga-debugger",
  "displayName": "VAmiga Debugger",
  "description": "Debug Amiga programs with an integrated VAmiga emulator in vscode",
  "version": "1.3.0",
  "author": "Graham Bates",
  "publisher": "gigabates",
  "license": "SEE LICENSE IN LICENSE.txt",
  "preview": false,
  "repository": "https://github.com/grahambates/vscode-vamiga-debugger.git",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Debuggers"
  ],
  "keywords": [
    "amiga",
    "debugger",
    "m68k",
    "vamiga",
    "assembly"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onDebugResolve:vamiga",
    "onDebugResolve:puae"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vamiga-debugger.stepBackFrame",
        "title": "Start of Frame",
        "icon": "$(run-above)",
        "enablement": "(debugType == 'vamiga' || debugType == 'puae') && debugState == 'stopped'"
      },
      {
        "command": "vamiga-debugger.eof",
        "title": "End of Frame",
        "icon": "$(run-below)",
        "enablement": "(debugType == 'vamiga' || debugType == 'puae') && debugState == 'stopped'"
      },
      {
        "command": "vamiga-debugger.eol",
        "title": "End of Line",
        "icon": "$(debug-line-by-line)",
        "enablement": "(debugType == 'vamiga' || debugType == 'puae') && debugState == 'stopped'"
      },
      {
        "command": "vamiga-debugger.openMemoryViewer",
        "title": "VAmiga: Open Memory Viewer",
        "icon": "$(symbol-array)"
      },
      {
        "command": "vamiga-debugger.viewVariableInMemory",
        "title": "View in Memory Viewer"
      },
      {
        "command": "vamiga-debugger.openStateViewer",
        "title": "VAmiga: Open State Viewer",
        "icon": "$(symbol-misc)"
      },
      {
        "command": "vamiga-debugger.openPuae",
        "title": "vAmiga (PUAE): Open Webview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "debugType == 'vamiga' || debugType == 'puae'"
        },
        {
          "command": "vamiga-debugger.viewVariableInMemory",
          "when": "false"
        },
        {
          "command": "vamiga-debugger.openStateViewer",
          "when": "debugType == 'vamiga' || debugType == 'puae'"
        }
      ],
      "debug/toolBar": [
        {
          "command": "vamiga-debugger.stepBackFrame",
          "when": "debugType == 'vamiga' || debugType == 'puae'",
          "group": "navigation@50"
        },
        {
          "command": "vamiga-debugger.eof",
          "when": "debugType == 'vamiga' || debugType == 'puae'",
          "group": "navigation@51"
        },
        {
          "command": "vamiga-debugger.eol",
          "when": "debugType == 'vamiga' || debugType == 'puae'",
          "group": "navigation@52"
        },
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "debugType == 'vamiga' || debugType == 'puae'",
          "group": "navigation@53"
        },
        {
          "command": "vamiga-debugger.openStateViewer",
          "when": "debugType == 'vamiga' || debugType == 'puae'",
          "group": "navigation@54"
        }
      ],
      "debug/variables/context": [
        {
          "command": "vamiga-debugger.viewVariableInMemory",
          "when": "debugType == 'vamiga' || debugType == 'puae'"
        }
      ],
      "editor/context": [
        {
          "command": "vamiga-debugger.openMemoryViewer",
          "when": "(debugType == 'vamiga' || debugType == 'puae') && editorLangId == m68k",
          "group": "debug@1"
        }
      ]
    },
    "configuration": {
      "title": "Vamiga Debugger",
      "properties": {
        "vamiga-debugger.defaultViewColumn": {
          "type": "string",
          "enum": [
            "one",
            "two",
            "three",
            "beside",
            "active"
          ],
          "enumDescriptions": [
            "First editor column",
            "Second editor column",
            "Third editor column",
            "Next to the active editor",
            "Same column as active editor"
          ],
          "default": "beside",
          "description": "Default position for the Vamiga emulator window"
        },
        "vamiga-debugger.memoryViewer.colorCodeHexBytes": {
          "type": "boolean",
          "default": true,
          "description": "Color-code byte/word/longword values in the memory viewer's Hex view by their leading hex digit, making patterns in the data easier to spot at a glance"
        }
      }
    },
    "breakpoints": [
      {
        "language": "m68k"
      }
    ],
    "debuggers": [
      {
        "type": "vamiga",
        "languages": [
          "m68k"
        ],
        "label": "vAmiga Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Amiga program to run",
                "default": "${workspaceFolder}/out/a.exe"
              },
              "debugProgram": {
                "type": "string",
                "description": "Optional alternate path to program file containing debug symbols. Defaults to same as 'program'. Making a separate build allows for a smaller exe loaded by the Amiga, which uses less RAM and loads faster.",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "Enable logging of the Debug Adapter Protocol",
                "default": false
              },
              "fastLoad": {
                "type": "boolean",
                "description": "Inject program directly into memory",
                "default": false
              },
              "kickstartRom": {
                "type": "string",
                "description": "Path to the Kickstart ROM file"
              },
              "kickstartExt": {
                "type": "string",
                "description": "Path to the extended Kickstart ROM file"
              },
              "emulatorOptions": {
                "type": "object",
                "properties": {
                  "cpuRevision": {
                    "type": "string",
                    "enum": [
                      "68000",
                      "68010",
                      "68020",
                      "68030",
                      "fake_68030"
                    ],
                    "description": "CPU model. \"fake_68030\" is an approximate 68030 (no MMU)."
                  },
                  "chipRam": {
                    "type": "string",
                    "enum": [
                      "256k",
                      "512k",
                      "1M",
                      "2M"
                    ],
                    "description": "Chip RAM size"
                  },
                  "slowRam": {
                    "type": "string",
                    "enum": [
                      "0",
                      "256k",
                      "512k"
                    ],
                    "description": "Slow RAM size"
                  },
                  "fastRam": {
                    "type": "string",
                    "enum": [
                      "0",
                      "256k",
                      "512k",
                      "1M",
                      "2M",
                      "8M"
                    ],
                    "description": "Fast RAM size"
                  },
                  "showNavBar": {
                    "type": "boolean",
                    "description": "Show navigation bar"
                  },
                  "wideScreen": {
                    "type": "boolean",
                    "description": "Stretch to full width, regardless of aspect ratio"
                  },
                  "darkMode": {
                    "type": "boolean",
                    "description": "Dark mode"
                  },
                  "enableMouse": {
                    "type": "boolean",
                    "description": "Enable mouse"
                  },
                  "displayZoom": {
                    "type": "string",
                    "enum": [
                      "viewport tracking",
                      "borderless",
                      "narrow",
                      "standard",
                      "wider",
                      "overscan",
                      "extreme"
                    ],
                    "description": "Display zoom mode"
                  },
                  "useGpu": {
                    "type": "boolean",
                    "description": "Render with GPU, rather than software"
                  },
                  "agnusRevision": {
                    "type": "string",
                    "enum": [
                      "OCS_OLD",
                      "OCS",
                      "ECS_1MB",
                      "ECS_2MB"
                    ],
                    "description": "Agnus chip revision"
                  },
                  "deniseRevision": {
                    "type": "string",
                    "enum": [
                      "OCS",
                      "ECS"
                    ],
                    "description": "Denise chip revision"
                  },
                  "cpuSpeed": {
                    "type": "string",
                    "enum": [
                      "7MHz",
                      "14Hz",
                      "21Hz",
                      "28Hz",
                      "35Hz",
                      "43Hz",
                      "57Hz",
                      "85Hz",
                      "99Hz"
                    ],
                    "description": "CPU speed"
                  },
                  "blitterAccuracy": {
                    "type": "number",
                    "enum": [
                      0,
                      1,
                      2
                    ],
                    "description": "Blitter accuracy level"
                  },
                  "floppyDriveCount": {
                    "type": "number",
                    "enum": [
                      1,
                      2,
                      3,
                      4
                    ],
                    "description": "Number of floppy drives"
                  },
                  "driveSpeed": {
                    "type": "number",
                    "enum": [
                      -1,
                      1,
                      2,
                      4,
                      8
                    ],
                    "description": "Floppy drive speed multiplier (-1: auto)"
                  }
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "vamiga",
            "request": "launch",
            "name": "Launch vAmiga",
            "program": "${workspaceFolder}/out/a.exe",
            "fastLoad": true,
            "stopOnEntry": true,
            "kickstartRom": "${workspaceFolder}/roms/kick13.rom",
            "emulatorOptions": {
              "chipRam": "512k",
              "slowRam": "512k",
              "fastRam": "0",
              "cpuRevision": "68000",
              "agnusRevision": "OCS",
              "deniseRevision": "OCS",
              "blitterAccuracy": 2,
              "cpuSpeed": "7MHz"
            }
          }
        ],
        "configurationSnippets": [
          {
            "label": "vAmiga: OCS 512k + 512k Slow",
            "description": "A500 OCS with 512k chip and slow RAM",
            "body": {
              "type": "vamiga",
              "request": "launch",
              "name": "vAmiga: OCS 512k + 512k Slow",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "kickstartRom": "^\"\\${workspaceFolder\\}/${2:roms/kick13.rom}\"",
              "emulatorOptions": {
                "chipRam": "512k",
                "slowRam": "512k",
                "fastRam": "0",
                "cpuRevision": "68000",
                "agnusRevision": "OCS",
                "deniseRevision": "OCS",
                "blitterAccuracy": 2,
                "cpuSpeed": "7MHz"
              }
            }
          },
          {
            "label": "vAmiga: ECS 1M + 1M Fast",
            "description": "A500 ECS with 1M chip and 1M fast RAM",
            "body": {
              "type": "vamiga",
              "request": "launch",
              "name": "vAmiga: ECS 1M + 1M Fast",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "kickstartRom": "^\"\\${workspaceFolder\\}/${2:roms/kick310.rom}\"",
              "emulatorOptions": {
                "chipRam": "1M",
                "slowRam": "0",
                "fastRam": "1M",
                "cpuRevision": "68000",
                "agnusRevision": "ECS_2MB",
                "deniseRevision": "ECS",
                "blitterAccuracy": 2,
                "cpuSpeed": "7MHz"
              }
            }
          }
        ]
      },
      {
        "type": "puae",
        "languages": [
          "m68k"
        ],
        "label": "PUAE Debug",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Amiga program to run",
                "default": "${workspaceFolder}/out/a.exe"
              },
              "debugProgram": {
                "type": "string",
                "description": "Optional alternate path to program file containing debug symbols. Defaults to same as 'program'.",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "trace": {
                "type": "boolean",
                "description": "Enable logging of the Debug Adapter Protocol",
                "default": false
              },
              "fastLoad": {
                "type": "boolean",
                "description": "Inject program directly into memory",
                "default": false
              },
              "kickstartRom": {
                "type": "string",
                "description": "Path to the Kickstart ROM file (required). Read from the host filesystem and embedded in the webview."
              },
              "emulatorConfigFile": {
                "type": "string",
                "description": "Path to a WinUAE-format .uae config file used as the base configuration (e.g. a quickstart preset). Values in emulatorOptions override it."
              },
              "emulatorOptions": {
                "type": "object",
                "description": "Raw WinUAE-format .uae key=value pairs. All keys are written verbatim to the emulator config. Any unlisted WinUAE key is also accepted.",
                "properties": {
                  "cpu_model": {
                    "type": "integer",
                    "enum": [
                      68000,
                      68010,
                      68020,
                      68030,
                      68040,
                      68060
                    ],
                    "description": "CPU model"
                  },
                  "chipmem_size": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      4
                    ],
                    "enumDescriptions": [
                      "512k",
                      "1M",
                      "2M"
                    ],
                    "description": "Chip RAM size (1=512k, 2=1M, 4=2M)"
                  },
                  "bogomem_size": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2
                    ],
                    "enumDescriptions": [
                      "0",
                      "256k",
                      "512k"
                    ],
                    "description": "Slow/Bogo RAM size (0=none, 1=256k, 2=512k)"
                  },
                  "fastmem_size": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2,
                      4,
                      8
                    ],
                    "enumDescriptions": [
                      "0",
                      "1M",
                      "2M",
                      "4M",
                      "8M"
                    ],
                    "description": "Fast RAM size in MB (0=none)"
                  },
                  "z3fastmem_size": {
                    "type": "integer",
                    "description": "Zorro III fast RAM size in MB (requires cpu_24bit_addressing=false)"
                  },
                  "quickstart": {
                    "type": "string",
                    "pattern": "^(A500\\+?|A600|A1000|A1200|A3000|A4000T?|CD32|CDTV-CR|CDTV|ARCADIA),\\d+$",
                    "description": "Machine preset: \"<Model>,<ConfigIndex>\" e.g. \"A1200,1\". Resets chipset/CPU/RAM — specify this key before memory/CPU keys so later lines override it."
                  },
                  "chipset": {
                    "type": "string",
                    "enum": [
                      "ocs",
                      "ecs_agnus",
                      "ecs_denise",
                      "ecs",
                      "aga"
                    ],
                    "description": "Chipset revision"
                  },
                  "chipset_compatible": {
                    "type": "string",
                    "enum": [
                      "-",
                      "Generic",
                      "CDTV",
                      "CDTV-CR",
                      "CD32",
                      "A500",
                      "A500+",
                      "A600",
                      "A1000",
                      "A1200",
                      "A2000",
                      "A3000",
                      "A3000T",
                      "A4000",
                      "A4000T",
                      "Velvet",
                      "Casablanca",
                      "DraCo"
                    ],
                    "description": "Machine compatibility preset (chipset timing/quirks)"
                  },
                  "cpu_compatible": {
                    "type": "boolean",
                    "description": "CPU compatibility mode (more accurate). Default: true."
                  },
                  "cpu_cycle_exact": {
                    "type": "boolean",
                    "description": "Cycle-exact CPU emulation. Default: true."
                  },
                  "cpu_memory_cycle_exact": {
                    "type": "boolean",
                    "description": "Cycle-exact CPU memory accesses. Default: true."
                  },
                  "blitter_cycle_exact": {
                    "type": "boolean",
                    "description": "Cycle-exact blitter emulation. Default: true."
                  },
                  "cpu_24bit_addressing": {
                    "type": "boolean",
                    "description": "Restrict CPU to 24-bit addressing. Set false to use Z3/P96 fast RAM."
                  },
                  "immediate_blits": {
                    "type": "boolean",
                    "description": "Perform blits immediately, ignoring blitter timing"
                  },
                  "cpu_speed": {
                    "description": "CPU speed: \"max\" (unlimited), \"real\" (real Amiga speed), or an integer multiplier 1–20",
                    "oneOf": [
                      {
                        "type": "string",
                        "enum": [
                          "max",
                          "real"
                        ]
                      },
                      {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 20
                      }
                    ]
                  },
                  "finegrain_cpu_speed": {
                    "type": "integer",
                    "description": "Fine-grained CPU speed (alternative to cpu_speed)"
                  },
                  "collision_level": {
                    "type": "string",
                    "enum": [
                      "none",
                      "sprites",
                      "playfields",
                      "full"
                    ],
                    "description": "Sprite/playfield collision detection level"
                  },
                  "nr_floppies": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 4,
                    "description": "Number of floppy drives"
                  },
                  "floppy_speed": {
                    "type": "integer",
                    "description": "Floppy speed as % of real speed (0=turbo/instant)"
                  },
                  "floppy0type": {
                    "type": "integer",
                    "enum": [ -1, 0, 1, 2 ],
                    "description": "DF0: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                  },
                  "floppy1type": {
                    "type": "integer",
                    "enum": [ -1, 0, 1, 2 ],
                    "description": "DF1: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                  },
                  "floppy2type": {
                    "type": "integer",
                    "enum": [ -1, 0, 1, 2 ],
                    "description": "DF2: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                  },
                  "floppy3type": {
                    "type": "integer",
                    "enum": [ -1, 0, 1, 2 ],
                    "description": "DF3: drive type (-1=none, 0=3.5\" DD, 1=3.5\" HD, 2=5.25\" SD)"
                  },
                  "sound_output": {
                    "type": "string",
                    "enum": [ "none", "interrupts", "good", "best" ],
                    "description": "Sound emulation quality/method"
                  },
                  "sound_stereo_separation": {
                    "type": "integer",
                    "description": "Stereo separation level (0–10)"
                  },
                  "sound_frequency": {
                    "type": "integer",
                    "description": "Audio sample rate in Hz"
                  },
                  "gfx_center_horizontal": {
                    "type": "string",
                    "enum": [ "none", "simple", "smart" ],
                    "description": "Horizontal display centering"
                  },
                  "gfx_center_vertical": {
                    "type": "string",
                    "enum": [ "none", "simple", "smart" ],
                    "description": "Vertical display centering"
                  },
                  "gfx_correct_aspect": {
                    "type": "boolean",
                    "description": "Correct aspect ratio (pixel doubling on PAL)"
                  }
                },
                "additionalProperties": {
                  "type": [ "string", "number", "boolean" ]
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "puae",
            "request": "launch",
            "name": "Launch PUAE",
            "program": "${workspaceFolder}/out/a.exe",
            "fastLoad": true,
            "stopOnEntry": true,
            "kickstartRom": "${workspaceFolder}/roms/kick13.rom",
            "emulatorOptions": {
              "chipmem_size": 2,
              "bogomem_size": 2,
              "cpu_model": 68000
            }
          }
        ],
        "configurationSnippets": [
          {
            "label": "PUAE: A500 OCS 512k chip + 512k slow",
            "description": "PUAE/ami9000 wasm backend - A500 OCS",
            "body": {
              "type": "puae",
              "request": "launch",
              "name": "PUAE: A500 OCS 512k + 512k Slow",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "kickstartRom": "^\"\\${workspaceFolder\\}/${2:roms/kick13.rom}\"",
              "emulatorOptions": {
                "cpu_model": 68000,
                "chipmem_size": 1,
                "bogomem_size": 2,
                "chipset": "ocs"
              }
            }
          },
          {
            "label": "PUAE: A1200 AGA 2M chip + 2M fast",
            "description": "PUAE/ami9000 wasm backend - A1200 AGA",
            "body": {
              "type": "puae",
              "request": "launch",
              "name": "PUAE: A1200 AGA 2M chip + 2M fast",
              "program": "^\"\\${workspaceFolder\\}/${1:out/a.exe}\"",
              "fastLoad": true,
              "stopOnEntry": true,
              "kickstartRom": "^\"\\${workspaceFolder\\}/${2:roms/kick31.rom}\"",
              "emulatorOptions": {
                "cpu_model": 68020,
                "chipmem_size": 4,
                "fastmem_size": 2,
                "chipset": "aga"
              }
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.js",
    "watch": "npm run check-types && node esbuild.js --watch",
    "package": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit && tsc --noEmit -p src/webview/tsconfig.json",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts,tsx",
    "test": "npm run test:unit && npm run test:wasm",
    "test:unit": "jest",
    "test:wasm": "node puae-wasm/test/test_g1.mjs && node puae-wasm/test/test_g2.mjs && node puae-wasm/test/test_g3.mjs && node puae-wasm/test/test_g4.mjs && node puae-wasm/test/test_g5.mjs && node puae-wasm/test/test_g6.mjs && node puae-wasm/test/test_reset.mjs && node puae-wasm/test/test_reverse.mjs",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.41",
    "@vscode/debugadapter": "^1.68.0",
    "downshift": "^9.0.10",
    "expr-eval": "^2.0.2",
    "m68kdecode": "^1.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.104.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vscode-elements/elements": "^2.3.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "sinon": "^21.0.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "extension.test.ts",
      "integration.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/test/**/*"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/jestSetup.ts"
    ]
  }
}
